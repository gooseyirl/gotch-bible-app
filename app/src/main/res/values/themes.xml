<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme with dark background and orange accent -->
    <style name="Theme.CardDeck" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color (orange accent) -->
        <item name="colorPrimary">@color/orange_accent</item>
        <item name="colorPrimaryVariant">@color/orange_accent_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/orange_accent</item>
        <item name="colorSecondaryVariant">@color/orange_accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Dark background and white text -->
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="editTextColor">@color/text_primary</item>
        <!-- Button style -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <!-- Dialog theme -->
        <item name="alertDialogTheme">@style/Theme.App.Dialog</item>
    </style>

    <!-- Custom button style matching screenshot -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange_accent</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Dark dialog theme -->
    <style name="Theme.App.Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/orange_accent</item>
        <item name="colorSecondary">@color/orange_accent</item>
        <item name="android:background">@color/dark_background</item>
        <item name="backgroundTint">@color/dark_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Button.Dialog</item>
    </style>

    <!-- Dialog button style -->
    <style name="Widget.App.Button.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/orange_accent</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
